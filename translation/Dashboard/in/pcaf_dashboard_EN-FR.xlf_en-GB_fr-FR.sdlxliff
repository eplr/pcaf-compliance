:seg-defs><sdl:cmt id="42186301-56a7-4ee4-a3c0-594d50e928d1"/></trans-unit></group><group><sdl:cxts><sdl:cxt id="1"/><sdl:cxt id="2"/><sdl:cxt id="3"/><sdl:node id="1"/></sdl:cxts><trans-unit id="268ac877-5fef-41be-9eea-e11a7cedc7d0"><source>Scoring Methodology:</source><seg-source><mrk mtype="seg" mid="43">Scoring Methodology:</mrk></seg-source><target><mrk mtype="seg" mid="43">Méthodologie de scoring :</mrk></target><sdl:seg-defs><sdl:seg id="43" conf="Translated" origin="interactive"><sdl:prev-origin origin="source"><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">RYexMpGxZ9r6zAKpJIZ+s/Sbr3oqTuRK6a2nuGOrUgs=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">02/19/2026 15:56:51</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value><sdl:value key="modified_on">02/19/2026 15:56:51</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">RYexMpGxZ9r6zAKpJIZ+s/Sbr3oqTuRK6a2nuGOrUgs=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">02/19/2026 20:05:48</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value><sdl:value key="modified_on">02/19/2026 20:06:46</sdl:value><sdl:value key="SDL:OriginalTranslationHash">511355532</sdl:value></sdl:seg></sdl:seg-defs><sdl:cmt id="e73b17e4-fac5-4f63-8ded-16b35464f57c"/></trans-unit></group><group><sdl:cxts><sdl:cxt id="1"/><sdl:cxt id="2"/><sdl:cxt id="3"/><sdl:node id="1"/></sdl:cxts><trans-unit id="3a9f5772-835f-4176-8fc5-fa89f10b4c99"><source>Score = PCAF Status (20% if signatory, 10% if mentioned) + Part A (40% if reported, 20% if partial) + Part B/C (15% if reported, 7.5% if partial) + Asset Classes (2.5% per class reported, 1.25% if partial).</source><seg-source><mrk mtype="seg" mid="44">Score = PCAF Status (20% if signatory, 10% if mentioned) + Part A (40% if reported, 20% if partial) + Part B/C (15% if reported, 7.5% if partial) + Asset Classes (2.5% per class reported, 1.25% if partial).</mrk></seg-source><target><mrk mtype="seg" mid="44">Score = statut PCAF® (20 % si signataire, 10 % si mention) + Partie A (40 % si reporting, 20 % si reporting partiel) + Parties B/C (15 % si reporting, 7,5 % si reporting partiel) + classes d’actifs (2,5 % par classe figurant dans le reporting, 1,25 % si reporting partiel).</mrk></target><sdl:seg-defs><sdl:seg id="44" conf="Translated" origin="interactive"><sdl:prev-origin origin="source"><sdl:prev-origin origin="source"><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">0Em54wGKQk3TeFxDOSQ1+kAAcw94P9RzZ7f3T9T3EjE=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">02/19/2026 15:56:51</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value><sdl:value key="modified_on">02/19/2026 15:56:51</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">0Em54wGKQk3TeFxDOSQ1+kAAcw94P9RzZ7f3T9T3EjE=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">02/19/2026 20:05:49</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value><sdl:value key="modified_on">02/19/2026 20:05:52</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">0Em54wGKQk3TeFxDOSQ1+kAAcw94P9RzZ7f3T9T3EjE=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">02/22/2026 17:50:46</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value><sdl:value key="modified_on">02/23/2026 08:41:30</sdl:value><sdl:value key="SDL:OriginalTranslationHash">291204270</sdl:value></sdl:seg></sdl:seg-defs><sdl:cmt id="c3a33e20-ad55-4e46-b628-c7eb7a521ebc"/></trans-unit></group><group><sdl:cxts><sdl:cxt id="1"/><sdl:cxt id="2"/><sdl:cxt id="3"/><sdl:node id="1"/></sdl:cxts><trans-unit id="78725e81-17b1-4035-9eff-85357e6ef319"><source>Example: KBC = 20% (signatory) + 40% (Part A) + 7.5% (Part B partial) + 7.5% (Part C partial) + 7.5% (3 asset classes) =</source><seg-source><mrk mtype="seg" mid="45">Example:</mrk> <mrk mtype="seg" mid="46">KBC = 20% (signatory) + 40% (Part A) + 7.5% (Part B partial) + 7.5% (Part C partial) + 7.5% (3 asset classes) =</mrk></seg-source><target><mrk mtype="seg" mid="45">Exemple :</mrk> <mrk mtype="seg" mid="46">KBC = 20 % (signataire) + 40 % (Partie A) + 7,5 % (reporting partiel Partie B) + 7,5 % (reporting partiel Partie C) + 7,5 % (3 classes d’actifs) =</mrk></target><sdl:seg-defs><sdl:seg id="45" conf="Translated" origin="interactive"><sdl:prev-origin origin="source"><sdl:prev-origin origin="tm" origin-system="ESMA_EN-FR" percent="72"><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">dwOfZgIcyI4e21VhEpSBTALefb24sBtUvpUv19lUPr4=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">01/21/2026 10:51:57</sdl:value><sdl:value key="modified_on">01/21/2026 10:51:57</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">dwOfZgIcyI4e21VhEpSBTALefb24sBtUvpUv19lUPr4=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">01/21/2026 10:51:57</sdl:value><sdl:value key="modified_on">02/19/2026 15:56:51</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">dwOfZgIcyI4e21VhEpSBTALefb24sBtUvpUv19lUPr4=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value key="created_on">02/19/2026 20:05:56</sdl:value><sdl:value key="modified_on">02/19/2026 20:05:56</sdl:value><sdl:value key="last_modified_by">FIDESTRA\fidestra</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-2097228063</sdl:value></sdl:seg><sdl:seg id="46" conf="Translated" origin="interactive"><sdl:prev-origin origin="source"><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">THrPaag2Vnfwq2RIL9ZJFL5Nz/92+ngWbKStWS5sU8Q=</sdl:value><sdl:value key="created_by">FIDESTRA\fidestra</sdl:value><sdl:value 