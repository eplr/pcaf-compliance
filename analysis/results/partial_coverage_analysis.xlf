          <target xml:lang="fr"></target>
          <note>SOCGEN – Parts A, B partial – 4/12 reported, 4/12 partial, 4/12 missing – 66.7%</note>
        </trans-unit>
        <trans-unit id="med_06_inst" resname="ageas_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>AGEAS – Parts A, C partial – 4/11 reported, 3/11 partial, 4/11 missing – 63.6%</note>
        </trans-unit>
        <trans-unit id="med_07_inst" resname="legalgeneral_type">
