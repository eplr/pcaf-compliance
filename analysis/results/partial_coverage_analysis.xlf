          <target xml:lang="fr"></target>
          <note>LEGAL &amp; GENERAL – Parts A, C partial – 5/11 reported, 2/11 partial, 4/11 missing – 63.6%</note>
        </trans-unit>
        <trans-unit id="med_08_inst" resname="swissre_type">
          <source xml:lang="en">Reinsurer</source>
          <target xml:lang="fr"></target>
          <note>SWISS RE – Part C partial – 6/11 reported, 1/11 partial, 4/11 missing – 63.6%</note>
        </trans-unit>
      </group>

      <!-- Low Coverage rows -->
      <group id="low_coverage" resname="low_coverage_section">
        <trans-unit id="low_01_inst" resname="admiral_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>ADMIRAL – Parts A, C partial – 1/11 reported, 4/11 partial, 6/11 missing – 45.5%</note>
        </trans-unit>
        <trans-unit id="low_02_inst" resname="deutscheboerse_type">
          <source xml:lang="en">Exchange</source>
          <target xml:lang="fr"></target>
          <note>DEUTSCHE BÖRSE – Part A partial – 1/10 reported, 3/10 partial, 6/10 missing – 40.0%</note>
        </trans-unit>
        <trans-unit id="low_03_inst" resname="gbl_type">
          <source xml:lang="en">Inv. Holding</source>
          <target xml:lang="fr"></target>
          <note>GBL – Part A partial – 2/10 reported, 2/10 partial, 6/10 missing – 40.0%</note>
        </trans-unit>
      </group>

      <!-- Footer -->
      <trans-unit id="footer_01" resname="footer_note">
        <source xml:lang="en">Coverage = (Reported + Partial) / Applicable asset classes</source>
        <target xml:lang="fr"></target>
      </trans-unit>
    </body>
  </file>
