<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-strict.xsd">
  <file original="partial_coverage_analysis.xlsx" source-language="en" target-language="fr" datatype="x-application/x-excel">
    <header>
      <note>PCAF Partial Coverage Analysis - Asset class coverage for institutions with partial PCAF reporting</note>
    </header>
    <body>
      <!-- Title -->
      <trans-unit id="title_01" resname="title">
        <source xml:lang="en">Asset Class Coverage for Institutions with "Partial" PCAF Reporting</source>
        <target xml:lang="fr"></target>
      </trans-unit>

      <!-- Legend -->
      <trans-unit id="legend_01" resname="legend_header">
        <source xml:lang="en">Applicable asset classes by institution type:</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="legend_02" resname="legend_bancassurance">
        <source xml:lang="en">Bancassurance: 13/13 (all classes applicable)</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="legend_03" resname="legend_banks">
        <source xml:lang="en">Banks: 12/13 (excl. Insurance Underwriting)</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="legend_04" resname="legend_insurers">
        <source xml:lang="en">Insurers / Reinsurers: 11/13 (excl. Capital Markets, Advisory Services)</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="legend_05" resname="legend_exchange">
        <source xml:lang="en">Exchange / Investment Holding: 10/13 (excl. Capital Markets, Advisory Services, Insurance Underwriting)</source>
        <target xml:lang="fr"></target>
      </trans-unit>

      <!-- Column headers -->
      <trans-unit id="header_01" resname="col_institution">
        <source xml:lang="en">Institution</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="header_02" resname="col_type">
        <source xml:lang="en">Type</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="header_03" resname="col_partial_parts">
        <source xml:lang="en">Partial Parts</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="header_04" resname="col_reported">
        <source xml:lang="en">Reported</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="header_05" resname="col_partial">
        <source xml:lang="en">Partial</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="header_06" resname="col_missing">
        <source xml:lang="en">Missing</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="header_07" resname="col_coverage">
        <source xml:lang="en">Coverage</source>
        <target xml:lang="fr"></target>
      </trans-unit>

      <!-- Section titles -->
      <trans-unit id="section_01" resname="section_high">
        <source xml:lang="en">High Coverage (≥ 80%)</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="section_02" resname="section_medium">
        <source xml:lang="en">Medium Coverage (60–80%)</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="section_03" resname="section_low">
        <source xml:lang="en">Low Coverage (&lt; 60%)</source>
        <target xml:lang="fr"></target>
      </trans-unit>

      <!-- Institution types -->
      <trans-unit id="type_01" resname="type_insurer">
        <source xml:lang="en">Insurer</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="type_02" resname="type_bank">
        <source xml:lang="en">Bank</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="type_03" resname="type_bancassurance">
        <source xml:lang="en">Bancassurance</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="type_04" resname="type_reinsurer">
        <source xml:lang="en">Reinsurer</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="type_05" resname="type_exchange">
        <source xml:lang="en">Exchange</source>
        <target xml:lang="fr"></target>
      </trans-unit>
      <trans-unit id="type_06" resname="type_inv_holding">
        <source xml:lang="en">Inv. Holding</source>
        <target xml:lang="fr"></target>
      </trans-unit>

      <!-- High Coverage rows -->
      <group id="high_coverage" resname="high_coverage_section">
        <trans-unit id="high_01_inst" resname="allianz_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>ALLIANZ – Part C partial – 7/11 reported, 4/11 partial, 0/11 missing – 100.0%</note>
        </trans-unit>
        <trans-unit id="high_02_inst" resname="commerzbank_type">
          <source xml:lang="en">Bank</source>
          <target xml:lang="fr"></target>
          <note>COMMERZBANK – Parts A, B partial – 9/12 reported, 3/12 partial, 0/12 missing – 100.0%</note>
        </trans-unit>
        <trans-unit id="high_03_inst" resname="unicredit_type">
          <source xml:lang="en">Bank</source>
          <target xml:lang="fr"></target>
          <note>UNICREDIT – Part B partial – 11/12 reported, 1/12 partial, 0/12 missing – 100.0%</note>
        </trans-unit>
        <trans-unit id="high_04_inst" resname="kbc_type">
          <source xml:lang="en">Bancassurance</source>
          <target xml:lang="fr"></target>
          <note>KBC – Parts B, C partial – 9/13 reported, 3/13 partial, 1/13 missing – 92.3%</note>
        </trans-unit>
        <trans-unit id="high_05_inst" resname="santander_type">
          <source xml:lang="en">Bank</source>
          <target xml:lang="fr"></target>
          <note>SANTANDER – Part B partial – 10/12 reported, 1/12 partial, 1/12 missing – 91.7%</note>
        </trans-unit>
        <trans-unit id="high_06_inst" resname="asrnederland_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>ASR NEDERLAND – Part C partial – 6/11 reported, 4/11 partial, 1/11 missing – 90.9%</note>
        </trans-unit>
        <trans-unit id="high_07_inst" resname="nordea_type">
          <source xml:lang="en">Bank</source>
          <target xml:lang="fr"></target>
          <note>NORDEA – Part B partial – 7/12 reported, 3/12 partial, 2/12 missing – 83.3%</note>
        </trans-unit>
        <trans-unit id="high_08_inst" resname="axa_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>AXA – Part C partial – 7/11 reported, 2/11 partial, 2/11 missing – 81.8%</note>
        </trans-unit>
        <trans-unit id="high_09_inst" resname="nngroup_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>NN GROUP – Parts A, C partial – 8/11 reported, 1/11 partial, 2/11 missing – 81.8%</note>
        </trans-unit>
      </group>

      <!-- Medium Coverage rows -->
      <group id="medium_coverage" resname="medium_coverage_section">
        <trans-unit id="med_01_inst" resname="aviva_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>AVIVA – Part C partial – 6/11 reported, 2/11 partial, 3/11 missing – 72.7%</note>
        </trans-unit>
        <trans-unit id="med_02_inst" resname="phoenixgroup_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>PHOENIX GROUP – Part C partial – 7/11 reported, 1/11 partial, 3/11 missing – 72.7%</note>
        </trans-unit>
        <trans-unit id="med_03_inst" resname="zurich_type">
          <source xml:lang="en">Insurer</source>
          <target xml:lang="fr"></target>
          <note>ZURICH – Parts A, C partial – 5/11 reported, 3/11 partial, 3/11 missing – 72.7%</note>
        </trans-unit>
        <trans-unit id="med_04_inst" resname="creditagricole_type">
          <source xml:lang="en">Bank</source>
